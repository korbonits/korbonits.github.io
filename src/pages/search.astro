---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Search" description="Search all posts on korbonits.com" />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <style>
      main { width: 720px; max-width: calc(100% - 2em); margin: auto; padding: 3em 1em; }

      .section-label {
        font-family: "DM Mono", monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #aaa;
        margin-bottom: 0.75rem;
      }

      .divider {
        border: none;
        border-top: 1px solid #e8e5e0;
        margin: 3rem 0;
      }

      /* Semantic search input */
      #semanticQuery {
        width: 100%;
        font-family: "Lora", serif;
        font-size: 1rem;
        padding: 0.65rem 0.85rem;
        border: 1px solid #d4d0c8;
        border-radius: 4px;
        background: #fff;
        color: #1a1a1a;
        box-sizing: border-box;
        transition: border-color 0.15s;
        margin-bottom: 1rem;
      }
      #semanticQuery:focus { outline: none; border-color: #888; }

      #semanticStatus {
        font-family: "DM Mono", monospace;
        font-size: 0.78rem;
        color: #aaa;
        min-height: 1.2rem;
        margin-bottom: 1rem;
      }

      /* Results */
      .sem-result {
        padding: 1rem 0;
        border-bottom: 1px solid #e8e5e0;
      }
      .sem-result:first-child { border-top: 1px solid #e8e5e0; }

      .sem-result-title {
        font-family: "Lora", serif;
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }
      .sem-result-title a {
        color: #1a1a1a;
        text-decoration: none;
        border-bottom: 1px solid #1a1a1a;
        padding-bottom: 1px;
      }
      .sem-result-title a:hover { color: #555; border-color: #555; }

      .sem-result-excerpt {
        font-size: 0.88rem;
        color: #666;
        line-height: 1.6;
        margin: 0;
      }

      .sem-result-score {
        font-family: "DM Mono", monospace;
        font-size: 0.68rem;
        color: #ccc;
        margin-left: 0.5rem;
      }

      /* Scatter plot */
      .scatter-hint {
        font-size: 0.85rem;
        color: #aaa;
        font-family: "DM Mono", monospace;
        margin-bottom: 1rem;
      }

      .scatter-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 3;
        border: 1px solid #e8e5e0;
        border-radius: 6px;
        overflow: hidden;
        background: #faf9f7;
      }

      #scatterPlot { display: block; width: 100%; height: 100%; }

      /* Dark mode */
      @media (prefers-color-scheme: dark) {
        .section-label { color: #4b5563; }
        .divider { border-top-color: #2a2f3d; }

        #semanticQuery {
          background: #1a1f2e;
          border-color: #2a2f3d;
          color: #e8eaf0;
        }
        #semanticQuery:focus { border-color: #6b7280; }

        #semanticStatus { color: #4b5563; }

        .sem-result { border-bottom-color: #2a2f3d; }
        .sem-result:first-child { border-top-color: #2a2f3d; }

        .sem-result-title a { color: #e8eaf0; border-bottom-color: #e8eaf0; }
        .sem-result-title a:hover { color: #9ca3af; border-color: #9ca3af; }

        .sem-result-excerpt { color: #9ca3af; }
        .sem-result-score { color: #374151; }

        .scatter-hint { color: #4b5563; }
        .scatter-wrap { background: #0f1219; border-color: #2a2f3d; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Search</h1>

      <p class="section-label">Keyword</p>
      <div id="search"></div>

      <hr class="divider" />

      <p class="section-label">Semantic</p>
      <input
        id="semanticQuery"
        type="text"
        placeholder="Describe what you're looking for…"
        autocomplete="off"
        spellcheck="false"
      />
      <p id="semanticStatus"></p>
      <div id="semanticResults"></div>

      <hr class="divider" />

      <p class="section-label">Embedding space</p>
      <p class="scatter-hint">Each dot is a post — similar writing clusters together. Click to open.</p>
      <div class="scatter-wrap">
        <canvas id="scatterPlot"></canvas>
      </div>
    </main>

    <Footer />

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" is:inline></script>

    <script is:inline>
      function initPagefind() {
        const el = document.getElementById('search');
        if (el) { el.innerHTML = ''; new PagefindUI({ element: '#search', showSubResults: true }); }
      }
      document.addEventListener('astro:page-load', initPagefind);
    </script>

    <script>
      // ── State ────────────────────────────────────────────────────────
      let corpusPosts = null;
      let corpusPCA = null;
      let scatterChart = null;
      const isDark = () => window.matchMedia('(prefers-color-scheme: dark)').matches;

      // ── Corpus ───────────────────────────────────────────────────────
      async function loadCorpus() {
        if (corpusPosts) return;
        try {
          const res = await fetch('/embeddings.json');
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const data = await res.json();
          // Support both old flat-array format and new {pca, posts} format
          if (Array.isArray(data)) {
            corpusPosts = data;
            corpusPCA = null;
          } else {
            corpusPosts = data.posts;
            corpusPCA = data.pca;
          }
        } catch {
          corpusPosts = [];
          corpusPCA = null;
        }
      }

      // ── PCA projection ───────────────────────────────────────────────
      function projectPoint(embedding, pca) {
        if (!pca) return null;
        const centered = embedding.map((v, i) => v - pca.mean[i]);
        return pca.components.map(comp =>
          comp.reduce((sum, c, i) => sum + c * centered[i], 0)
        );
      }

      // ── Cosine similarity ────────────────────────────────────────────
      function cosineSim(a, b) {
        let dot = 0, na = 0, nb = 0;
        for (let i = 0; i < a.length; i++) {
          dot += a[i] * b[i];
          na += a[i] * a[i];
          nb += b[i] * b[i];
        }
        return dot / (Math.sqrt(na) * Math.sqrt(nb));
      }

      // ── Scatter plot ─────────────────────────────────────────────────
      function initScatter(posts) {
        const canvas = document.getElementById('scatterPlot');
        if (!canvas || !window.Chart) return;
        if (!posts.length || posts[0].x == null) return; // no PCA coords yet

        if (scatterChart) scatterChart.destroy();

        const dark = isDark();
        const gridColor = dark ? 'rgba(255,255,255,0.03)' : 'rgba(0,0,0,0.03)';

        scatterChart = new Chart(canvas.getContext('2d'), {
          type: 'scatter',
          data: {
            datasets: [
              {
                label: 'posts',
                data: posts.map(p => ({ x: p.x, y: p.y, title: p.title, url: p.url })),
                backgroundColor: dark ? 'rgba(139,148,255,0.5)' : 'rgba(99,102,241,0.45)',
                borderColor: dark ? 'rgba(139,148,255,0.8)' : 'rgba(99,102,241,0.7)',
                borderWidth: 1,
                pointRadius: 5,
                pointHoverRadius: 7,
              },
              {
                label: 'results',
                data: [],
                backgroundColor: 'rgba(16,185,129,0.85)',
                borderColor: 'rgba(16,185,129,1)',
                borderWidth: 1.5,
                pointRadius: 8,
                pointHoverRadius: 10,
              },
              {
                label: 'query',
                data: [],
                backgroundColor: 'rgba(239,68,68,0.9)',
                borderColor: 'rgba(239,68,68,1)',
                borderWidth: 2,
                pointRadius: 10,
                pointHoverRadius: 12,
                pointStyle: 'crossRot',
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 250 },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: ctx => ctx.raw.title || (ctx.datasetIndex === 2 ? 'query' : ''),
                },
              },
            },
            scales: {
              x: { display: false },
              y: { display: false },
            },
            onClick(e, elements) {
              if (!elements.length) return;
              const { datasetIndex, index } = elements[0];
              const pt = scatterChart.data.datasets[datasetIndex].data[index];
              if (pt?.url) window.location.href = pt.url;
            },
            onHover(e, elements) {
              e.native.target.style.cursor = elements.length ? 'pointer' : 'default';
            },
          },
        });
      }

      function updateScatter(queryCoord, topPosts) {
        if (!scatterChart) return;
        scatterChart.data.datasets[1].data = topPosts
          .filter(p => p.x != null)
          .map(p => ({ x: p.x, y: p.y, title: p.title, url: p.url }));
        scatterChart.data.datasets[2].data = queryCoord
          ? [{ x: queryCoord[0], y: queryCoord[1], title: 'query', url: null }]
          : [];
        scatterChart.update();
      }

      // ── Render results ────────────────────────────────────────────────
      function renderResults(results) {
        const el = document.getElementById('semanticResults');
        if (!results.length) { el.innerHTML = ''; return; }
        el.innerHTML = results.map(({ title, url, excerpt, score }) => `
          <div class="sem-result">
            <p class="sem-result-title">
              <a href="${url}">${title}</a>
              <span class="sem-result-score">${Math.round(score * 100)}%</span>
            </p>
            <p class="sem-result-excerpt">${excerpt}</p>
          </div>
        `).join('');
      }

      // ── Semantic search ───────────────────────────────────────────────
      async function semanticSearch(query) {
        const status = document.getElementById('semanticStatus');

        if (!query.trim()) {
          status.textContent = '';
          document.getElementById('semanticResults').innerHTML = '';
          updateScatter(null, []);
          return;
        }

        status.textContent = 'Searching…';

        try {
          await loadCorpus();

          const [embedRes] = await Promise.all([
            fetch('/api/embed-query', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ text: query }),
            }),
          ]);

          if (!embedRes.ok) throw new Error(`embed-query HTTP ${embedRes.status}`);
          const { embedding } = await embedRes.json();

          const scored = corpusPosts
            .map(post => ({ ...post, score: cosineSim(embedding, post.embedding) }))
            .sort((a, b) => b.score - a.score)
            .slice(0, 5);

          const queryCoord = projectPoint(embedding, corpusPCA);
          updateScatter(queryCoord, scored);

          status.textContent = `${scored.length} results`;
          renderResults(scored);
        } catch (e) {
          console.error('semantic search error:', e);
          status.textContent = 'Something went wrong.';
        }
      }

      // ── Init ──────────────────────────────────────────────────────────
      let debounceTimer;

      document.addEventListener('astro:page-load', async () => {
        // Wire up keyword search
        const searchEl = document.getElementById('search');
        if (searchEl) { searchEl.innerHTML = ''; new PagefindUI({ element: '#search', showSubResults: true }); }

        // Load corpus and init scatter immediately
        await loadCorpus();
        if (corpusPosts?.length) initScatter(corpusPosts);

        // Wire up semantic input
        const input = document.getElementById('semanticQuery');
        if (!input) return;

        input.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(() => semanticSearch(input.value), 400);
        });
      });
    </script>
  </body>
</html>

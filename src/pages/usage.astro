---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import tokenUsage from '../data/token-usage.json';

const title = 'Token Usage';
const description = 'Daily Anthropic API token usage broken down by model.';

// ── Data prep ──────────────────────────────────────────────────────────────
const dates  = [...new Set(tokenUsage.map((r: any) => r.date as string))].sort();
const models = [...new Set(tokenUsage.map((r: any) => r.model as string))].sort();

// Fast lookup: "date|model" → record
const lookup = new Map(
  tokenUsage.map((r: any) => [`${r.date}|${r.model}`, r])
);

// Palette — cycles if there are more models than colours
const PALETTE = [
  '#6366f1', '#f59e0b', '#10b981', '#ef4444',
  '#3b82f6', '#8b5cf6', '#ec4899', '#14b8a6',
  '#f97316', '#84cc16', '#06b6d4', '#a855f7',
];

const datasets = models.map((model, i) => ({
  label: model,
  data: dates.map(d => {
    const r: any = lookup.get(`${d}|${model}`);
    return r ? r.input_tokens + r.output_tokens : null;
  }),
  borderColor:     PALETTE[i % PALETTE.length],
  backgroundColor: PALETTE[i % PALETTE.length] + '33',
  tension: 0.35,
  fill: false,
  pointRadius: 4,
  spanGaps: true,
}));

const chartConfig = JSON.stringify({ labels: dates, datasets });

// ── Summary stats ──────────────────────────────────────────────────────────
const totalInput  = tokenUsage.reduce((s: number, r: any) => s + (r.input_tokens  ?? 0), 0);
const totalOutput = tokenUsage.reduce((s: number, r: any) => s + (r.output_tokens ?? 0), 0);
const totalCached = tokenUsage.reduce((s: number, r: any) => s + (r.cached_input_tokens ?? 0), 0);
const totalTokens = totalInput + totalOutput;
const fmt = (n: number) => n.toLocaleString('en-US');

const lastDate = dates.at(-1);
const hasData  = tokenUsage.length > 0;
---
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script
      src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"
      is:inline
    ></script>
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 960px;
        margin: 2em auto;
        padding: 0 1em;
      }
      h1 { margin-bottom: 0.25em; }
      .subtitle {
        color: rgb(var(--gray));
        font-size: 0.9em;
        margin-bottom: 2em;
      }
      .stats {
        display: flex;
        gap: 1.5em;
        flex-wrap: wrap;
        margin-bottom: 2em;
      }
      .stat {
        background: rgb(var(--gray-light));
        border-radius: 8px;
        padding: 1em 1.5em;
        min-width: 140px;
      }
      .stat-label {
        font-size: 0.78em;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.3em;
      }
      .stat-value {
        font-size: 1.4em;
        font-weight: 700;
      }
      .chart-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 6;
        margin-bottom: 2.5em;
      }
      .no-data {
        text-align: center;
        padding: 4em 2em;
        color: rgb(var(--gray));
        border: 2px dashed rgb(var(--gray-light));
        border-radius: 8px;
        margin-bottom: 2em;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88em;
      }
      th, td {
        padding: 0.5em 0.75em;
        text-align: left;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      th {
        font-size: 0.8em;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: rgb(var(--gray));
        background: rgb(var(--gray-light));
      }
      td:nth-child(n+3) { text-align: right; font-variant-numeric: tabular-nums; }
      tr:hover td { background: rgb(var(--gray-light), 0.5); }
      .model-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 6px;
        vertical-align: middle;
      }
      @media (max-width: 600px) {
        .chart-wrap { aspect-ratio: 4 / 3; }
        table { font-size: 0.78em; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Token Usage</h1>
      <p class="subtitle">
        Anthropic API token consumption by model · daily snapshots
        {lastDate && <span>· last updated {lastDate}</span>}
      </p>

      {hasData ? (
        <>
          <!-- Summary cards -->
          <div class="stats">
            <div class="stat">
              <div class="stat-label">Total tokens</div>
              <div class="stat-value">{fmt(totalTokens)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Input tokens</div>
              <div class="stat-value">{fmt(totalInput)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Output tokens</div>
              <div class="stat-value">{fmt(totalOutput)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Cache reads</div>
              <div class="stat-value">{fmt(totalCached)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Models</div>
              <div class="stat-value">{models.length}</div>
            </div>
          </div>

          <!-- Line chart -->
          <div class="chart-wrap">
            <canvas id="usageChart"></canvas>
          </div>

          <!-- Data table -->
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Model</th>
                <th>Input</th>
                <th>Output</th>
                <th>Cache reads</th>
                <th>Cache writes</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {[...tokenUsage as any[]].reverse().map((r: any, i: number) => (
                <tr>
                  <td>{r.date}</td>
                  <td>
                    <span
                      class="model-dot"
                      style={`background:${PALETTE[models.indexOf(r.model) % PALETTE.length]}`}
                    ></span>
                    {r.model}
                  </td>
                  <td>{fmt(r.input_tokens)}</td>
                  <td>{fmt(r.output_tokens)}</td>
                  <td>{fmt(r.cached_input_tokens ?? 0)}</td>
                  <td>{fmt(r.cache_creation_input_tokens ?? 0)}</td>
                  <td>{fmt(r.input_tokens + r.output_tokens)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      ) : (
        <div class="no-data">
          <p>No data yet.</p>
          <p>Add an <code>ANTHROPIC_ADMIN_API_KEY</code> secret to your repository and run the
            <strong>Update Token Usage</strong> workflow to populate this page.</p>
        </div>
      )}
    </main>
    <Footer />

    {hasData && (
      <script define:vars={{ chartConfig }}>
        const config = JSON.parse(chartConfig);
        new Chart(document.getElementById('usageChart'), {
          type: 'line',
          data: config,
          options: {
            responsive: true,
            maintainAspectRatio: true,
            interaction: { mode: 'index', intersect: false },
            plugins: {
              legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16 } },
              tooltip: {
                callbacks: {
                  label: ctx =>
                    ` ${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString('en-US') ?? '—'} tokens`,
                },
              },
            },
            scales: {
              x: {
                grid: { display: false },
                ticks: { maxRotation: 45, autoSkip: true, maxTicksLimit: 14 },
              },
              y: {
                beginAtZero: true,
                ticks: {
                  callback: v =>
                    v >= 1_000_000
                      ? (v / 1_000_000).toFixed(1) + 'M'
                      : v >= 1_000
                      ? (v / 1_000).toFixed(0) + 'k'
                      : v,
                },
              },
            },
          },
        });
      </script>
    )}
  </body>
</html>
